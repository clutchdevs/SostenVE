# .gitignore — base para Node.js y Python.
# El stack definitivo se decide en ADR-0001; depurar según el lenguaje elegido.

# --- Secretos y entorno (NUNCA versionar) ---
.env
.env.*
!.env.example
*.pem
*.key
secrets/

# --- Node.js ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
dist/
build/
coverage/
.cache/
.next/
next-env.d.ts
.turbo/
*.tsbuildinfo

# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.coverage
htmlcov/

# --- Base de datos / respaldos locales ---
*.sqlite
*.sqlite3
*.dump
*.sql.gz
backups/

# --- Herramientas locales (config personal, no del proyecto) ---
.claude/

# --- Editores / SO ---
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# --- Logs ---
*.log
logs/
