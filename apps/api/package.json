{
  "name": "@ppv/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "PPV backend — serverless Hono API on Vercel + Supabase",
  "scripts": {
    "prebuild": "node ../../scripts/build-config.mjs",
    "build": "tsc -p tsconfig.build.json",
    "predev": "node ../../scripts/build-config.mjs",
    "dev": "tsx watch dev.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "type-check": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.11",
    "@hono/swagger-ui": "^0.6.1",
    "@node-rs/argon2": "2.0.2",
    "@supabase/supabase-js": "^2.110.8",
    "hono": "^4.12.31",
    "jose": "^6.2.4",
    "js-yaml": "^5.2.1",
    "nodemailer": "^9.0.3",
    "typescript": "^7.0.2",
    "write-excel-file": "^4.1.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.7.5",
    "@types/nodemailer": "^6.4.16",
    "tsx": "^4.19.1",
    "vitest": "^4.1.10"
  }
}
