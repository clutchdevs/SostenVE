# SostenVE — secrets only. Copy to .env and fill with real values.
# Everything that is NOT a secret lives in config/app.config.yml (versioned).
# Rule: if changing it requires rotating a credential or affects credential
# security -> here. Otherwise -> config/app.config.yml.

# PostgreSQL connection string (use the Supabase connection POOLER URL,
# not the direct connection, because serverless functions open/close
# connections constantly — see ADR-0002).
DATABASE_URL=

# Supabase project URL (not a secret, but required by the official client and
# kept here next to its keys for deployment convenience).
SUPABASE_URL=

# Supabase keys
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# Shared secret verified on the Vercel Cron endpoint (see ADR-0009)
CRON_SECRET=

# SMTP password for volunteer notification emails
SMTP_PASSWORD=

# Secret used to sign JWT access/refresh tokens (see ADR-0005)
JWT_SECRET=

# Secret salt for the pseudonymized ID (HMAC-SHA256) linking PII to clinical
# data (see ADR-0011). Rotating it breaks the link to existing pseudonyms.
PSEUDONYMIZATION_SALT=

# 32-byte key (base64 or hex) for AES-256-GCM column encryption of clinical
# fields at rest (see ADR-0004).
ENCRYPTION_KEY=
