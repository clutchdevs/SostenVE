# =============================================================================
# SostenVE — variables de entorno.  FUENTE ÚNICA para desarrollo local.
#
#   1) Copia este archivo:   cp .env.example .env
#   2) `docker compose up` ya funciona con los valores de DESARROLLO de abajo.
#   3) Rellena solo los secretos REALES marcados (SMTP / FPV) si los necesitas.
#
# `.env` está en .gitignore (no se versiona). `docker-compose.yml` LEE de aquí:
# no pongas valores en el compose, ponlos aquí.
#
# En PRODUCCIÓN (Vercel) NO se usa este archivo ni el compose: cada variable se
# configura en el entorno del proyecto en Vercel. Los valores de abajo son
# LOCAL-DEV y NO sirven para producción — regenera los secretos con `openssl`.
#
# Regla del proyecto: los secretos van aquí; lo NO secreto va en
# config/app.config.yml (versionado).
# =============================================================================

# --- Supabase (stack local del CLI) ------------------------------------------
# URL y claves DEMO estándar del Supabase local — son públicas, no secretas.
# `host.docker.internal` = el contenedor del API alcanza al host donde corre
# Supabase (`supabase start`). En prod: URL y claves reales del proyecto Supabase.
SUPABASE_URL=http://host.docker.internal:54321
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU

# Conexión PostgreSQL. En dev: el Postgres del stack local. En prod: la URL del
# POOLER de Supabase (no la directa — serverless abre/cierra conexiones, ADR-0002).
DATABASE_URL=postgresql://postgres:postgres@host.docker.internal:54322/postgres

# --- Secretos de la app (VALORES DEV — regenerar para producción) ------------
# En prod genera unos reales y ponlos en Vercel:
#   openssl rand -base64 48   (JWT_SECRET)
#   openssl rand -base64 32   (ENCRYPTION_KEY — debe decodificar a 32 bytes)
#   openssl rand -base64 32   (PSEUDONYMIZATION_SALT)
#   openssl rand -hex 32      (CRON_SECRET)

# Firma de tokens de acceso/refresh (ADR-0005).
JWT_SECRET=local-dev-jwt-secret-at-least-32-bytes!!

# Sal del ID seudonimizado (HMAC-SHA256) que liga PII ↔ datos clínicos (ADR-0011).
# Rotarla rompe el vínculo con los seudónimos existentes.
PSEUDONYMIZATION_SALT=local-dev-pseudonym-salt

# Clave de 32 bytes (base64 o hex) para cifrar columnas clínicas en reposo con
# AES-256-GCM (ADR-0004). Debe decodificar a EXACTAMENTE 32 bytes o la app no arranca.
ENCRYPTION_KEY=bG9jYWwtZGV2LTMyLWJ5dGUtZW5jcnlwdGlvbi1rZXk=

# Secreto compartido que valida el endpoint de cron de Vercel (ADR-0009).
CRON_SECRET=local-dev-cron-secret

# --- Email (SMTP, RF-2.2.4) — SECRETO REAL (opcional en dev) -----------------
# Por defecto (EMAIL_PROVIDER vacío) el notifier NO envía, solo loguea. Para
# enviar de verdad pon EMAIL_PROVIDER=smtp y los SMTP_* (sobreescriben
# config/app.config.yml → email.*). Solo SMTP_PASSWORD es secreto duro.
#
# Gmail (necesita cuenta con 2FA + "App Password"):
#   EMAIL_PROVIDER=smtp
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USERNAME=tu-correo@gmail.com
#   SMTP_FROM=PPV <tu-correo@gmail.com>     # Gmail fuerza From = la cuenta
#   SMTP_PASSWORD=<App Password de 16 dígitos, sin espacios>
#
# Otros: Brevo smtp-relay.brevo.com:587 · SendGrid smtp.sendgrid.net:587 (user
# "apikey") · Mailtrap sandbox.smtp.mailtrap.io:2525 (sandbox, sin envío real).
EMAIL_PROVIDER=
SMTP_HOST=
SMTP_PORT=
SMTP_USERNAME=
SMTP_FROM=
SMTP_PASSWORD=

# --- Padrón FPV — SECRETO REAL ----------------------------------------------
# Token X-API-TOKEN del padrón (issue #6), usado por el verificador `http` en
# dev y prod. Sin él, el registro cae a pending_approval. Los tests (NODE_ENV=test)
# usan el dummy y no lo necesitan.
FPV_API_TOKEN=

# --- Upstash Redis (presencia RF-2.5) — solo PRODUCCIÓN ----------------------
# Solo si config presence.provider = "upstash". En dev/test la presencia es en
# memoria y no necesita nada.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
